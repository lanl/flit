#export LD_LIBRARY_PATH=$mpiroot/lib/release:$LD_LIBRARY_PATH

# ==============================================================================
# Compilation settings

use_mpi ?= on
use_hdf5 ?= on

# Compilers
ifeq ($(use_mpi), on)
	fc = mpiifx
else
	fc = ifx
endif
cc = icx
cxx = icpx
ll = ar

# Paths
intelroot = $(HOME)/intel
mklroot = $(intelroot)/mkl
mpiroot = $(intelroot)/mpi
hdf5root = $(HOME)/tool/hdf5

# Include paths
base_inc = \
	-I$(mklroot)/include \
	-I$(mklroot)/include/fftw \
	-I$(mklroot)/include/intel64/lp64

ifeq ($(use_mpi), on)
	base_inc += \
		-I$(mpiroot)/include
endif

ifeq ($(use_hdf5), on)
	base_inc += \
		-I$(hdf5root)/include
endif

# Link options
base_lflags = \
	-qmkl -qopenmp -lstdc++ -lstdc++fs \
	-L$(intelroot)/lib \
	-L$(mklroot)/lib \
	$(mklroot)/lib/libmkl_core.a \
	$(mklroot)/lib/libmkl_intel_thread.a \
	$(mklroot)/lib/libmkl_intel_lp64.a \
	$(mklroot)/lib/libmkl_blas95_lp64.a \
	$(mklroot)/lib/libmkl_lapack95_lp64.a
	#	-qmkl -qopenmp -lstdc++ -lstdc++fs -liomp5 -lpthread -lm \

ifeq ($(use_mpi), on)
	base_lflags += \
		-L$(mpiroot)/lib \
		-L$(mpiroot)/lib/release
endif

ifeq ($(use_hdf5), on)
	base_lflags += \
		-L$(hdf5root)/lib -lhdf5_fortran -lhdf5 -lz -ldl
endif

# Compilation options
base_fflags = \
	-O3 -fpp -traceback -warn unused -module $(moddir) -qmkl \
	-assume byterecl -assume buffered_io -qopenmp -heap-arrays \
	-gen-interfaces -xHost -fp-model=consistent -fpscomp logicals
	#	-standard-semantics
	#	-align all -falign-loops -xHost -fp-model precise \
	#	-O0 -g -check bounds

ifeq ($(use_hdf5), on)
	base_fflags += \
		-D_use_hdf5_
endif

base_cflags = \
	-O3 -w -qopenmp -std=c17 \
	-Wno-implicit-function-declaration \
	-Wno-implicit-int \
	-Wno-pointer-to-int-cast
	#	-U__STRICT_ANSI__

base_cxxflags = \
	-O3 -w -qopenmp -std=c++20 -lstdc++fs


